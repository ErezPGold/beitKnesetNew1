<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Assets\770-background.jpeg" />
    <None Remove="Assets\jerusalem-joyful.jpeg" />
    <None Remove="Data\yahrzeits.json" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NodaTime" Version="3.3.2" />
    <PackageReference Include="Zmanim" Version="1.5.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\770-background.jpeg" />
    <Resource Include="Assets\jerusalem-joyful.jpeg" />
    <Content Include="Data\yahrzeits.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <None Update="parshiot.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
    <None Update="prayers.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
