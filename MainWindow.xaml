<Window x:Class="BeitKnessetDisplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="תצוגת בית כנסת"
        WindowState="Maximized"
        WindowStyle="None"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI, David, Arial Hebrew">
    <Window.Background>
        <ImageBrush ImageSource="Assets/jerusalem-joyful.jpeg" Stretch="UniformToFill" Opacity="0.55"/>
    </Window.Background>
    <Window.Resources>
        <LinearGradientBrush x:Key="WoodBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3E2A1A" Offset="0"/>
            <GradientStop Color="#A87C4F" Offset="0.5"/>
            <GradientStop Color="#3E2A1A" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GoldTrim" Color="#E8B86D"/>
        <LinearGradientBrush x:Key="CardBg" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E61E2F4D" Offset="0"/>
            <GradientStop Color="#E62A3F6B" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="GlassBg" Color="#CC1B2A4E"/>
        <SolidColorBrush x:Key="GoldText" Color="#E8B86D"/>
        <SolidColorBrush x:Key="LightText" Color="#F4E4BC"/>
        <SolidColorBrush x:Key="WarmAccent" Color="#D4956A"/>
        <SolidColorBrush x:Key="Ivory" Color="#F0F2F8"/>
        <SolidColorBrush x:Key="Muted" Color="#A8B5CC"/>

        <!-- Card עם רקע 770 רב-שכבתי + מסגרת זהב פנימית (אופציה B) -->
        <!-- Card עם רקע 770 רב-שכבתי (אופציה B) -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource GoldTrim}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.75" BlurRadius="18" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Background">
                <Setter.Value>
                    <VisualBrush Stretch="Fill" TileMode="None">
                        <VisualBrush.Visual>
                            <Grid Width="600" Height="400">
                                <!-- שכבה 1: בסיס Navy כהה -->
                                <Rectangle Fill="#0B1F3A"/>

                                <!-- שכבה 2: רקע 770 -->
                                <Rectangle>
                                    <Rectangle.Fill>
                                        <ImageBrush ImageSource="pack://application:,,,/Assets/770-background.jpeg"
                                            Stretch="UniformToFill"
                                            Opacity="0.45"/>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <!-- שכבה 3: שכבת כהוי לקריאות -->
                                <Rectangle Fill="#0B1F3A" Opacity="0.55"/>
                            </Grid>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GoldTrim}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ivory}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style x:Key="LearnLabel" TargetType="TextBlock" BasedOn="{StaticResource Label}">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="LearnValue" TargetType="TextBlock" BasedOn="{StaticResource Value}">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LineHeight" Value="46"/>
        </Style>

        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="20" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="AnimatedCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PulseIcon" TargetType="TextBlock">
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="TextBlock.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="1" To="1.1" Duration="0:0:2"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="1" To="1.1" Duration="0:0:2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WoodBrush}" Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.9" BlurRadius="30" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="38">
            <Border BorderBrush="{StaticResource GoldTrim}" BorderThickness="2" CornerRadius="4">
                <Grid>
                    <Rectangle Fill="#4D000000"/>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- ===== HEADER ===== -->
                        <Border Grid.Row="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- שעון + מזג אוויר -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Clock}" FontFamily="Consolas" FontSize="64"
                       Foreground="{StaticResource Ivory}" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentTemperature}" Style="{StaticResource Value}"
                       FontSize="26" FlowDirection="LeftToRight" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding WeatherCondition}" Style="{StaticResource Value}"
                       FontSize="20" Foreground="{StaticResource Muted}"/>
                                </StackPanel>

                                <!-- כותרת + תאריך -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="ברוכים הבאים לבית הכנסת" FontSize="40"
                       Foreground="{StaticResource GoldTrim}" FontWeight="Bold" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding HebrewDate}" Style="{StaticResource Value}"
                       FontSize="30" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding GregorianDate}" Style="{StaticResource Value}"
                       FontSize="22" Foreground="{StaticResource Muted}"/>
                                </StackPanel>

                                <!-- פרשה + הפטרה -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="פרשת השבוע" Style="{StaticResource Label}"/>
                                    <TextBlock Text="{Binding Parasha}" Style="{StaticResource Value}" FontSize="26"/>
                                    <TextBlock Text="הפטרה" Style="{StaticResource Label}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding Haftarah}" Style="{StaticResource Value}"
                       FontSize="20" Foreground="{StaticResource Muted}"/>
                                </StackPanel>

                                <!-- זמני שבת -->
                                <Border Grid.Column="3" Background="#1B2A4E" CornerRadius="12"
                Padding="16,12" Margin="8,0"
                BorderBrush="#E8B86D" BorderThickness="2"
                VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="זמני שבת" Foreground="#E8B86D" FontSize="20"
                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ShabbatCity}" Foreground="#F4E4BC"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,2,0,6"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <StackPanel Margin="10,0">
                                                <TextBlock Text="🕯 הדלקת נרות" Foreground="#F4E4BC"
                                   FontSize="14" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding CandleLighting}" Foreground="White"
                                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Width="1" Background="#E8B86D" Margin="8,4"/>
                                            <StackPanel Margin="10,0">
                                                <TextBlock Text="✨ צאת השבת" Foreground="#F4E4BC"
                                   FontSize="14" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding Havdalah}" Foreground="White"
                                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- סוף Header -->

                        <!-- ===== CONTENT ===== -->
                        <Grid Grid.Row="1">

                            <!-- ===== דשבורד: זמני היום בצדדים + 2 כרטיסים גדולים במרכז ===== -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDashboardVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="280"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>

                                <!-- צד ימין: זמני היום -->
                                <Border Grid.Column="0" Background="#F6EFD8" BorderBrush="#B8842D" BorderThickness="2" CornerRadius="14" Padding="12" Margin="0,10,10,10">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="זמני היום" FontSize="32" FontWeight="Bold" Foreground="#52330E" TextAlignment="Center" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding RightZmanim}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FFF9EA" BorderBrush="#D7AD55" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="23" FontWeight="SemiBold" Foreground="#53320B" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Time}" FontSize="29" FontWeight="Bold" Foreground="#0B4F6C" FlowDirection="LeftToRight" Margin="10,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DockPanel>
                                </Border>

                                <!-- מרכז: מקסימום 2 כרטיסים גדולים -->
                                <UniformGrid Grid.Column="1" Columns="1" Rows="2" Margin="8,8">
                                    <Border BorderBrush="#C29B35" BorderThickness="3" CornerRadius="18" Padding="26" Margin="8" Background="#FFF7DF">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="{Binding LearningTitle1}" FontSize="50" FontWeight="Bold" Foreground="#52330E" TextAlignment="Center" Margin="0,0,0,14"/>
                                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="8">
                                                <TextBlock Text="{Binding LearningBody1}" Width="980" FontSize="58" FontWeight="Bold" Foreground="#102A43" TextWrapping="Wrap" TextAlignment="Center" LineHeight="72"/>
                                            </Viewbox>
                                        </DockPanel>
                                    </Border>

                                    <Border BorderBrush="#8AA98A" BorderThickness="3" CornerRadius="18" Padding="26" Margin="8" Background="#F0F7EA">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top" Text="{Binding LearningTitle2}" FontSize="50" FontWeight="Bold" Foreground="#29422A" TextAlignment="Center" Margin="0,0,0,14"/>
                                            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="8">
                                                <TextBlock Text="{Binding LearningBody2}" Width="980" FontSize="58" FontWeight="Bold" Foreground="#102A43" TextWrapping="Wrap" TextAlignment="Center" LineHeight="72"/>
                                            </Viewbox>
                                        </DockPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- צד שמאל: המשך זמני היום -->
                                <Border Grid.Column="2" Background="#EAF4F6" BorderBrush="#5E9CAF" BorderThickness="2" CornerRadius="14" Padding="12" Margin="10,10,0,10">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="המשך זמנים" FontSize="32" FontWeight="Bold" Foreground="#143D4A" TextAlignment="Center" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding LeftZmanim}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8FEFF" BorderBrush="#9DC7D3" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="23" FontWeight="SemiBold" Foreground="#143D4A" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Time}" FontSize="29" FontWeight="Bold" Foreground="#8A4B0F" FlowDirection="LeftToRight" Margin="10,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <!-- ===== תזכורת ===== -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReminderVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Style="{StaticResource AnimatedCard}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="📣" Style="{StaticResource PulseIcon}"/>
                                        <TextBlock Text="{Binding ReminderTitle}" Style="{StaticResource Label}" FontSize="56"/>
                                        <TextBlock Text="{Binding ReminderBody}" Style="{StaticResource Value}" FontSize="38" Margin="20" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- ===== זמני תפילות ===== -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPrayerTimesVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Style="{StaticResource AnimatedCard}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🕍" Style="{StaticResource PulseIcon}"/>
                                        <TextBlock Text="זמני תפילות" Style="{StaticResource Label}" FontSize="56"/>
                                        <TextBlock Text="{Binding Prayers}" Style="{StaticResource Value}" FontSize="36" Margin="20"/>
                                    </StackPanel>
                                </Border>
                            </Grid>


                            <!-- ===== רפואה ===== -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRefuahVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Style="{StaticResource AnimatedCard}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="💙" Style="{StaticResource PulseIcon}"/>
                                        <TextBlock Text="להצלחה ולרפואה שלמה" Style="{StaticResource Label}" FontSize="56"/>
                                        <ItemsControl ItemsSource="{Binding RefuahNames}" Margin="0,20,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource Value}" FontSize="36" Margin="0,6" TextAlignment="Center"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- ===== נשמה ===== -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNeshamaVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Style="{StaticResource AnimatedCard}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="🕯" Style="{StaticResource PulseIcon}"/>
                                        <TextBlock Text="לעילוי נשמת" Style="{StaticResource Label}" FontSize="56"/>
                                        <ItemsControl ItemsSource="{Binding NeshamaNames}" Margin="0,20,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Style="{StaticResource Value}" FontSize="36" Margin="0,6" TextAlignment="Center"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>


                            <!-- ===== יום הילולא ===== -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource AnimatedCard}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsYahrzeitVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🕯" Style="{StaticResource PulseIcon}"/>
                                    <TextBlock Text="{Binding YahrzeitHeader}" Style="{StaticResource Label}" FontSize="50"/>
                                    <ItemsControl ItemsSource="{Binding Yahrzeits}" Margin="0,20,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,10">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource Label}" FontSize="34"/>
                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Value}" FontSize="24" Margin="20,4,20,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
