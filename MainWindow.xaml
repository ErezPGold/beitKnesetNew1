<Window x:Class="BeitKnessetDisplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="תצוגת בית כנסת"
        WindowState="Maximized"
        WindowStyle="None"
        FlowDirection="RightToLeft"
        FontFamily="Segoe UI, David, Arial Hebrew">
    <Window.Background>
        <ImageBrush ImageSource="Assets/jerusalem-joyful.jpeg" 
                Stretch="UniformToFill" 
                Opacity="0.55"/>
    </Window.Background>
    <Window.Resources>
        <!-- מסגרת זהובה זוהרת -->
        <LinearGradientBrush x:Key="WoodBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B4513" Offset="0"/>
            <GradientStop Color="#D4A574" Offset="0.5"/>
            <GradientStop Color="#8B4513" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GoldTrim" Color="#FFD700"/>

        <!-- כרטיסיות עם שקיפות חמה - מאפשרת לראות את הרקע -->
        <LinearGradientBrush x:Key="CardBg" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E61a1a3e" Offset="0"/>
            <GradientStop Color="#E62d1b4e" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="GlassBg" Color="#CC0a0a2e"/>

        <!-- צבעי טקסט חמים -->
        <SolidColorBrush x:Key="GoldText" Color="#FFD700"/>
        <SolidColorBrush x:Key="LightText" Color="#FFF8E7"/>
        <SolidColorBrush x:Key="WarmAccent" Color="#FF8C42"/>

        <!-- ===== מסגרת – כחול עמוק עם זהב ===== -->
        
        <LinearGradientBrush x:Key="WoodHighlight" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#e8c45a" Offset="0"/>
            <GradientStop Color="#d4af37" Offset="0.5"/>
            <GradientStop Color="#8a6f1f" Offset="1"/>
        </LinearGradientBrush>       
        
        <SolidColorBrush x:Key="Ivory"   Color="#e8edf3"/>
        <SolidColorBrush x:Key="Muted"   Color="#9bb3cc"/>

        <!-- ===== סגנונות ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldTrim}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.7" BlurRadius="16" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GoldTrim}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ivory}"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LearnLabel" TargetType="TextBlock" BasedOn="{StaticResource Label}">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="LearnValue" TargetType="TextBlock" BasedOn="{StaticResource Value}">
            <Setter Property="FontSize" Value="44"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LineHeight" Value="56"/>
        </Style>
        <!-- ===== אנימציות ===== -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                     From="0" To="1" Duration="0:0:0.6"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                     From="20" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- סגנון כרטיסיה מונפש -->
        <Style x:Key="AnimatedCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                </EventTrigger>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- אנימציית הבהוב לאייקון נר -->
        <Style x:Key="CandleIcon" TargetType="TextBlock">
            <Setter Property="FontSize" Value="48"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="TextBlock.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="1" To="1.15" Duration="0:0:1.2"/>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="1" To="0.75" Duration="0:0:1.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- אייקון מסתובב עדין (לכותרות) -->
        <Style x:Key="PulseIcon" TargetType="TextBlock">
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="TextBlock.Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="1" To="1.1" Duration="0:0:2"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="1" To="1.1" Duration="0:0:2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- ===== מסגרת חיצונית כחול-זהב ===== -->
    <Border Background="{StaticResource WoodBrush}" Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.9" BlurRadius="30" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="38">
            <Border BorderBrush="{StaticResource GoldTrim}" BorderThickness="2" CornerRadius="4">
                <!-- ===== רקע ירושלים (כיפת הסלע + הכותל) ===== -->
                <Grid>
                    <!-- שכבת כהות עדינה לקריאות בלבד (30% במקום 80%) -->
                    <Rectangle Fill="#4D000000"/>

                    <!-- ===== תוכן ===== -->
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ===== HEADER ===== -->
                        <Border Grid.Row="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Clock}" FontFamily="Consolas"
                                               FontSize="64" Foreground="{StaticResource Ivory}"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentTemperature}" Style="{StaticResource Value}" FontSize="26"
                                               FlowDirection="LeftToRight" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding WeatherCondition}" Style="{StaticResource Value}" FontSize="20" Foreground="{StaticResource Muted}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="ברוכים הבאים לבית הכנסת" FontSize="40"
                                               Foreground="{StaticResource GoldTrim}" FontWeight="Bold"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="{Binding HebrewDate}" Style="{StaticResource Value}" FontSize="30" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding GregorianDate}" Style="{StaticResource Value}" FontSize="22" Foreground="{StaticResource Muted}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock Text="פרשת השבוע" Style="{StaticResource Label}"/>
                                    <TextBlock Text="{Binding Parasha}" Style="{StaticResource Value}" FontSize="26"/>
                                    <TextBlock Text="הפטרה" Style="{StaticResource Label}" Margin="0,8,0,0"/>
                                    <TextBlock Text="{Binding Haftarah}" Style="{StaticResource Value}" FontSize="20" Foreground="{StaticResource Muted}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ===== CONTENT ===== -->
                        <Grid Grid.Row="1">

                            <!-- ===== דשבורד ===== -->
                            
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDashboardVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <!-- עמוד לימוד 1 -->
                                <UniformGrid Columns="3" Rows="2">
                                    <UniformGrid.Style>
                                        <Style TargetType="UniformGrid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLearningPage1}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </UniformGrid.Style>

                                    <Border Style="{StaticResource Card}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="📖 " FontSize="32" Foreground="{StaticResource GoldTrim}"/>
                                                <TextBlock Text="תהילים יומי" Style="{StaticResource LearnLabel}"/>
                                            </StackPanel>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Tehillim}" Style="{StaticResource LearnValue}"
                                                                    MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="📜 " FontSize="32" Foreground="{StaticResource GoldTrim}"/>
                                                <TextBlock  Text="חומש (עליה יומית)" Style="{StaticResource LearnLabel}"/>
                                            </StackPanel>                                            
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Chumash}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="📚 " FontSize="32" Foreground="{StaticResource GoldTrim}"/>
                                                <TextBlock Text="דף יומי" Style="{StaticResource LearnLabel}"/>
                                            </StackPanel>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding DafYomi}" Style="{StaticResource LearnValue}"
                                                                MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="📚 " FontSize="32" Foreground="{StaticResource GoldTrim}"/>
                                                <TextBlock Text="רמב״ם (ג׳ פרקים)" Style="{StaticResource LearnLabel}"/>
                                            </StackPanel>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Rambam}" Style="{StaticResource LearnValue}"
                                                        MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="💎 " FontSize="32" Foreground="{StaticResource GoldTrim}"/>
                                                <TextBlock Text="תניא יומי" Style="{StaticResource LearnLabel}"/>
                                            </StackPanel>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Tanya}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="היום יום" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding HayomYom}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                </UniformGrid>

                                <!-- עמוד לימוד 2 -->
                                <UniformGrid Columns="3" Rows="2">
                                    <UniformGrid.Style>
                                        <Style TargetType="UniformGrid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLearningPage2}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </UniformGrid.Style>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="משנה יומית" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Mishna}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="ירושלמי יומי" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Yerushalmi}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="הלכה יומית" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Halakha}" Style="{StaticResource LearnValue}"
                                                                MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="תנ״ך יומי" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding TanakhYomi}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="929" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Yom929}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="חק לישראל" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding ChokLeYisrael}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                </UniformGrid>

                                <!-- עמוד לימוד 3 -->
                                <UniformGrid Columns="2" Rows="2">
                                    <UniformGrid.Style>
                                        <Style TargetType="UniformGrid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLearningPage3}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </UniformGrid.Style>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="רמב״ם (פרק אחד)" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding Rambam1Perek}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="ערוך השולחן היומי" Style="{StaticResource LearnLabel}"/>
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding ArukhHaShulchan}" Style="{StaticResource LearnValue}"
                                                            MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource AnimatedCard}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- כותרת בשורה 0 -->
                                            <TextBlock Grid.Row="0" Text="משיב הרוח / מוריד הטל" Style="{StaticResource LearnLabel}"/>

                                            <!-- טקסט גשם בשורה 1 -->
                                            <Viewbox Grid.Row="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding GeshemText}" Style="{StaticResource LearnValue}"
                                                    MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>

                                            <!-- טקסט טל בשורה 2 -->
                                            <Viewbox Grid.Row="2" Stretch="Uniform" StretchDirection="DownOnly" Margin="10">
                                                <TextBlock Text="{Binding TalText}" Style="{StaticResource LearnValue}"
                                                    MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Viewbox>
                                        </Grid>
                                    </Border>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource AnimatedCard}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsShabbatMevarchim}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="שבת מברכים" Style="{StaticResource Label}"/>
                                            <TextBlock Text="{Binding ShabbatMevarchimText}" Style="{StaticResource Value}"/>
                                            <TextBlock Text="{Binding MoladText}" Style="{StaticResource Value}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                </UniformGrid>
                            </Grid>
                            <!-- ===== תזכורת ===== -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource AnimatedCard}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReminderVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ReminderTitle}" Style="{StaticResource Label}" FontSize="60"/>
                                    <TextBlock Text="{Binding ReminderBody}"  Style="{StaticResource Value}" FontSize="40" Margin="20"/>
                                </StackPanel>
                            </Border>

                            <!-- ===== זמני תפילות ===== -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource AnimatedCard}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPrayerTimesVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🕍" Style="{StaticResource PulseIcon}"/>
                                    <TextBlock Text="זמני תפילות" Style="{StaticResource Label}" FontSize="56"/>
                                    <TextBlock Text="{Binding Prayers}" Style="{StaticResource Value}" FontSize="36" Margin="20"/>
                                </StackPanel>
                            </Border>

                            <!-- ===== לרפואה שלמה ===== -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource AnimatedCard}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRefuahVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="💙" Style="{StaticResource PulseIcon}"/>
                                    <TextBlock Text="להצלחה ולרפואה שלמה" Style="{StaticResource Label}" FontSize="56"/>
                                    <ItemsControl ItemsSource="{Binding RefuahList}" Margin="0,20,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Style="{StaticResource Value}" FontSize="38" Margin="0,8"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ===== לעילוי נשמה ===== -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource AnimatedCard}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNeshamaVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🕯  לעילוי נשמת" Style="{StaticResource Label}" FontSize="56"/>
                                    <ItemsControl ItemsSource="{Binding NeshamaList}" Margin="0,20,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" Style="{StaticResource Value}" FontSize="38" Margin="0,8"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ===== יום הילולא ===== -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsYahrzeitVisible}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding YahrzeitHeader}" Style="{StaticResource Label}" FontSize="50"/>
                                    <ItemsControl ItemsSource="{Binding Yahrzeits}" Margin="0,20,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource Value}" FontSize="34" Margin="0,6"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ===== ZMANIM BAR ===== -->
                        <Border Grid.Row="2" Style="{StaticResource Card}">
                            <ItemsControl ItemsSource="{Binding Zmanim}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="6,2">
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource Label}" FontSize="18"/>
                                            <TextBlock Text="{Binding Time}" Style="{StaticResource Value}" FontSize="22"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>